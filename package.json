{
  "name": "StarChat",
  "version": "1.0.0",
  "author": "ShanhaiSky",
  "description": "纯前端 AI 对话应用",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^1.0.0",
    "@hugeicons/vue": "^1.0.0",
    "element-plus": "^2.8.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "sass": "^1.77.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.shanhaisky.starchat",
    "productName": "StarChat",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "!**/node_modules/**/{test,tests,__tests__}/**",
      "!**/node_modules/**/*.{md,txt,map}",
      "!**/node_modules/.cache/**"
    ],
    "asar": true,
    "asarUnpack": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/vite.svg"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "compression": "maximum",
      "unicode": true,
      "allowElevation": true
    }
  }
}
